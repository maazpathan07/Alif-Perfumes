rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function isAdmin() {
      return request.auth != null;
    }
    
    match /{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin()
                   && request.resource.size < 5 * 1024 * 1024 // 5MB Limit
                   && request.resource.contentType.matches('image/.*'); // Only Images
    }
  }
}
